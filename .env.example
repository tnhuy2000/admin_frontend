# Server Configuration (no VITE_ prefix for server-side only vars)
APP_PORT=4002
APP_BASENAME_PATH=/web-admin

# Backend URLs
BACKEND_URL=http://localhost:4001

# GraphQL Code Generation (used by codegen CLI)
GRAPHQL_URI_GEN=http://localhost:4001/graphql

# Client-side environment variables (VITE_ prefix required)
VITE_BACKEND_URL=http://localhost:4001
VITE_GRAPHQL_WEBSOCKET_URI=false
VITE_FILE_PATH_PREFIX=/webinfo_files/
